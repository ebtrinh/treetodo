# Copy to .env and fill in. PUBLIC_ vars are exposed to the browser (safe for anon key).
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Do NOT prefix with PUBLIC_. Never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
